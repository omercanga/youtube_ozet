# OpenRouter API (zorunlu)
OPENROUTER_API_KEY=your-openrouter-api-key-here

# AI Model (opsiyonel, varsayılan: openai/gpt-3.5-turbo)
# Seçenekler: google/gemini-2.0-flash, anthropic/claude-3-haiku
AI_MODEL=openai/gpt-3.5-turbo

# Transkript: AI'a gönderilecek max karakter (varsayılan: 8000)
# MAX_TRANSCRIPT_CHARS=8000

# Transkript: Supadata API (opsiyonel — youtube-transcript-api rate limit'e girince kullanılır)
# Ücretsiz kayıt: https://supadata.ai
# SUPADATA_API_KEY=your-supadata-api-key-here

# Transkript: YouTube cookies dosyası (opsiyonel — premium videolar için)
# YOUTUBE_COOKIES_PATH=/app/data/cookies.txt

# Database (opsiyonel, varsayılan: SQLite)
# DATABASE_URL=sqlite:////app/data/app.db

# CORS (opsiyonel, production'da kısıtla)
# CORS_ORIGINS=https://yourdomain.com
